{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "CommonJS", // <-- Change ESNext to CommonJS
    "moduleResolution": "node",
    "target": "ES2020",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "esModuleInterop": true, // <-- Essential for importing 'express'
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "declaration": true
  },
  "include": ["src/**/*.ts", "src/app.ts"],
  "exclude": ["node_modules", "dist"]
}
